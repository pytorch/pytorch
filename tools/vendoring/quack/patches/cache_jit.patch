     else:
-        cache_dir = Path(tempfile.gettempdir()) / getuser() / "quack_cache"
+        cache_dir = Path(tempfile.gettempdir()) / getuser() / "torch_vendor_quack_cache"
     cache_dir.mkdir(parents=True, exist_ok=True)
     return cache_dir

@@ -75,7 +75,7 @@
