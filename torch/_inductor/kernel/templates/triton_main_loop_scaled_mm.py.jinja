@triton.jit
def unpack_fp4_e2m1(x):
    bits = x.to(tl.uint8, bitcast=True)
    lo = decode_fp4_e2m1(bits & 0xF)
    hi = decode_fp4_e2m1(bits >> 4)
    return lo, hi


@triton.jit
def decode_fp4_e2m1(bits):
    sign = tl.where((bits & 0x8) == 0, 1.0, -1.0)
    exp = (bits >> 1) & 0x3
    mant = bits & 0x1
    mag = tl.where(
        exp == 0,
        mant.to(tl.float32) * 0.5,
        tl.exp2(exp.to(tl.float32) - 1.0) * (1.0 + mant.to(tl.float32) * 0.5),
    )
    return sign * mag


@triton.jit
def blockwise1xTILESIZE_swizzled_offsets(row_offs_scale, col_offs_scale, k_blocks):
    num_col_tiles = tl.cdiv(k_blocks, 4)
    tile_offset = 512 * ((row_offs_scale[:, None] // 128) * num_col_tiles + (col_offs_scale[None, :] // 4))
    outer = row_offs_scale[:, None] % 128
    inner = col_offs_scale[None, :] % 4
    return tile_offset + (outer % 32) * 16 + (outer // 32) * 4 + inner


@triton.jit
def blockwise1xTILESIZE_scale(
    pid,
    scale,
    ki,
    lhs_size,
    k_blocks,
    BLOCK_lhs: tl.constexpr,
    BLOCK_K: tl.constexpr,
    TILE_SIZE: tl.constexpr,
):
    row_offs_scale = pid * BLOCK_lhs + tl.arange(0, BLOCK_lhs)
    col_offs_scale = ki * tl.cdiv(BLOCK_K, TILE_SIZE) + tl.arange(0, (BLOCK_K + TILE_SIZE - 1) // TILE_SIZE)
    mask = (row_offs_scale[:, None] < lhs_size) & (col_offs_scale[None, :] < k_blocks)
    return tl.load(
        scale + blockwise1xTILESIZE_swizzled_offsets(row_offs_scale, col_offs_scale, k_blocks),
        mask=mask,
        other=127,
    ).to(tl.uint8, bitcast=True)


@triton.jit
def blockwise1xTILESIZE_scaling(
    pid,
    scale,
    ki,
    lhs_size,
    lhs_blocks,
    k_blocks,
    BLOCK_lhs: tl.constexpr,
    BLOCK_K: tl.constexpr,
    MIN_BLOCK_TILE_K: tl.constexpr,
    TILE_SIZE: tl.constexpr,
    SCALE_RECIPE: tl.constexpr,
):
    row_offs_scale = pid * BLOCK_lhs + tl.arange(0, BLOCK_lhs)
    col_offs_scale = ki * tl.cdiv(BLOCK_K, TILE_SIZE) + tl.arange(0, (BLOCK_K + TILE_SIZE - 1) // TILE_SIZE)
    {%- if SCALE_RECIPE_A in (2, 3) or SCALE_RECIPE_B in (2, 3) %}
    ptrs = scale + blockwise1xTILESIZE_swizzled_offsets(row_offs_scale, col_offs_scale, k_blocks)
    {%- else %}
    ptrs = scale + row_offs_scale[:, None] * k_blocks + col_offs_scale[None, :]
    {%- endif %}
    mask = (row_offs_scale[:, None] < lhs_size) & (col_offs_scale[None, :] < k_blocks)
    scale_block_raw = tl.load(ptrs, mask=mask, other=1.0)
    if SCALE_RECIPE == 3:
        scale_block = tl.exp2(scale_block_raw.to(tl.uint8, bitcast=True).to(tl.float32) - 127.0)
    elif SCALE_RECIPE == 2:
        scale_bits = scale_block_raw.to(tl.uint8, bitcast=True)
        scale_exp = (scale_bits >> 3) & 0xF
        scale_mant = scale_bits & 0x7
        scale_block = tl.where(
            scale_exp == 0,
            tl.exp2(-6.0) * (scale_mant.to(tl.float32) / 8.0),
            tl.exp2(scale_exp.to(tl.float32) - 7.0) * (1.0 + scale_mant.to(tl.float32) / 8.0),
        )
    else:
        scale_block = scale_block_raw.to(tl.float32)

    scale_expanded = scale_block[:, :, None]
    scale_expanded = tl.broadcast_to(
        scale_expanded,
        (BLOCK_lhs, (BLOCK_K + TILE_SIZE - 1) // TILE_SIZE, MIN_BLOCK_TILE_K)
    )
    scale_expanded = scale_expanded.reshape(
        BLOCK_lhs,
        ((BLOCK_K + TILE_SIZE - 1) // TILE_SIZE) * MIN_BLOCK_TILE_K
    )

    return scale_expanded


@triton.jit
def blockwise128x128_scaling(
    pid,
    scale,
    ki,
    lhs_blocks,
    k_blocks,
    BLOCK_lhs: tl.constexpr,
    BLOCK_K: tl.constexpr,
    MIN_BLOCK_TILE_lhs: tl.constexpr,
    MIN_BLOCK_TILE_K: tl.constexpr,
):
    row_offs_scale = pid * tl.cdiv(BLOCK_lhs, 128) + tl.arange(0, (BLOCK_lhs + 128 - 1) // 128)
    col_offs_scale = ki * tl.cdiv(BLOCK_K, 128) + tl.arange(0, (BLOCK_K + 128 - 1) // 128)
    ptrs = scale + row_offs_scale[:, None] * k_blocks + col_offs_scale[None, :]
    mask = (row_offs_scale[:, None] < lhs_blocks) & (col_offs_scale[None, :] < k_blocks)
    scale_block = tl.load(ptrs, mask=mask, other=1.0)

    scale_expanded = scale_block[:, :, None, None]
    scale_expanded = tl.broadcast_to(
        scale_expanded,
        ((BLOCK_lhs + 128 - 1) // 128, (BLOCK_K + 128 - 1) // 128, MIN_BLOCK_TILE_lhs, MIN_BLOCK_TILE_K)
    )
    scale_expanded = scale_expanded.reshape(
        ((BLOCK_lhs + 128 - 1) // 128) * MIN_BLOCK_TILE_lhs,
        ((BLOCK_K + 128 - 1) // 128) * MIN_BLOCK_TILE_K
    )

    return scale_expanded
